.include $::180MCU_MODELS/design.ngspice
.lib $::180MCU_MODELS/sm141064.ngspice typical
"}
C {code_shown.sym} 4290 -270 0 0 {name=s1 only_toplevel=false value="
.control
save all

** RSTn: low until 100ns then high
alter @V_RSTn[PWL] = [ 0 0  100n 0  100.001n 3.3  30m 3.3 ]

** Single latching clock pulse around 200ns
alter @V_clk[PWL] = [ 0 0  200n 0  200.001n 3.3  300n 3.3  300.001n 0  30m 0 ]

** EN[0..15]: all high after RSTn release
alter @V_EN0[PWL] = [ 0 0  150n 0  150.001n 3.3  30m 3.3 ]
alter @V_EN1[PWL] = [ 0 0  150n 0  150.001n 3.3  30m 3.3 ]
alter @V_EN2[PWL] = [ 0 0  150n 0  150.001n 3.3  30m 3.3 ]
alter @V_EN3[PWL] = [ 0 0  150n 0  150.001n 3.3  30m 3.3 ]
alter @V_EN4[PWL] = [ 0 0  150n 0  150.001n 3.3  30m 3.3 ]
alter @V_EN5[PWL] = [ 0 0  150n 0  150.001n 3.3  30m 3.3 ]
alter @V_EN6[PWL] = [ 0 0  150n 0  150.001n 3.3  30m 3.3 ]
alter @V_EN7[PWL] = [ 0 0  150n 0  150.001n 3.3  30m 3.3 ]
alter @V_EN8[PWL] = [ 0 0  150n 0  150.001n 3.3  30m 3.3 ]
alter @V_EN9[PWL] = [ 0 0  150n 0  150.001n 3.3  30m 3.3 ]
alter @V_EN10[PWL] = [ 0 0  150n 0  150.001n 3.3  30m 3.3 ]
alter @V_EN11[PWL] = [ 0 0  150n 0  150.001n 3.3  30m 3.3 ]
alter @V_EN12[PWL] = [ 0 0  150n 0  150.001n 3.3  30m 3.3 ]
alter @V_EN13[PWL] = [ 0 0  150n 0  150.001n 3.3  30m 3.3 ]
alter @V_EN14[PWL] = [ 0 0  150n 0  150.001n 3.3  30m 3.3 ]
alter @V_EN15[PWL] = [ 0 0  150n 0  150.001n 3.3  30m 3.3 ]

** MODE: stim phase 0-15ms (includes drain), record phase 15-30ms
alter @V_MODE[PWL]  = [ 0 0    15m 0    15.0001m 3.3   30m 3.3 ]
alter @V_MODEb[PWL] = [ 0 3.3  15m 3.3  15.0001m 0     30m 0 ]

** Brain LFPs: 100uV (10mV in source units, see scaling) 1kHz sines on 1.65V mid-rail,
** with 22.5deg phase increments per channel so REC traces are visually distinguishable.
alter @V_brain0[SIN] = [ 1.65 10m 1k 0 0 0.0000 ]
alter @V_brain1[SIN] = [ 1.65 10m 1k 0 0 22.5000 ]
alter @V_brain2[SIN] = [ 1.65 10m 1k 0 0 45.0000 ]
alter @V_brain3[SIN] = [ 1.65 10m 1k 0 0 67.5000 ]
alter @V_brain4[SIN] = [ 1.65 10m 1k 0 0 90.0000 ]
alter @V_brain5[SIN] = [ 1.65 10m 1k 0 0 112.5000 ]
alter @V_brain6[SIN] = [ 1.65 10m 1k 0 0 135.0000 ]
alter @V_brain7[SIN] = [ 1.65 10m 1k 0 0 157.5000 ]
alter @V_brain8[SIN] = [ 1.65 10m 1k 0 0 180.0000 ]
alter @V_brain9[SIN] = [ 1.65 10m 1k 0 0 202.5000 ]
alter @V_brain10[SIN] = [ 1.65 10m 1k 0 0 225.0000 ]
alter @V_brain11[SIN] = [ 1.65 10m 1k 0 0 247.5000 ]
alter @V_brain12[SIN] = [ 1.65 10m 1k 0 0 270.0000 ]
alter @V_brain13[SIN] = [ 1.65 10m 1k 0 0 292.5000 ]
alter @V_brain14[SIN] = [ 1.65 10m 1k 0 0 315.0000 ]
alter @V_brain15[SIN] = [ 1.65 10m 1k 0 0 337.5000 ]

** Stim driver: biphasic pulses at 0.5/1.5/2.5/3.5/4.5 ms during stim phase,
** then held at mid-rail for 10 ms drain before MODE switches.
alter @V_stim[PWL] = [
+ 0          1.65
+ 500u       1.65
+ 500.001u   0.65
+ 600u       0.65
+ 600.001u   2.65
+ 700u       2.65
+ 700.001u   1.65
+ 1500u      1.65
+ 1500.001u  0.65
+ 1600u      0.65
+ 1600.001u  2.65
+ 1700u      2.65
+ 1700.001u  1.65
+ 2500u      1.65
+ 2500.001u  0.65
+ 2600u      0.65
+ 2600.001u  2.65
+ 2700u      2.65
+ 2700.001u  1.65
+ 3500u      1.65
+ 3500.001u  0.65
+ 3600u      0.65
+ 3600.001u  2.65
+ 3700u      2.65
+ 3700.001u  1.65
+ 4500u      1.65
+ 4500.001u  0.65
+ 4600u      0.65
+ 4600.001u  2.65
+ 4700u      2.65
+ 4700.001u  1.65
+ 30m        1.65 ]

tran 1u 30m 0 5u

** plots
set color0 = white
set nolegend

** Plot a representative 4 channels (0,4,8,12): MODE marker, REC traces, E traces, scaled IPG traces
plot (v(MODE)*16.65/3.3)+0.825 v(REC0) v(REC1)+1 v(REC2)+2 v(REC3)+3 v(REC4)+4 v(REC5)+5 v(REC6)+6 v(REC7)+7 v(REC8)+8 v(REC9)+9 v(REC10)+10 v(REC11)+11 v(REC12)+12 v(REC13)+13 v(REC14)+14 v(REC15)+15 v(E0) v(E1)+1 v(E2)+2 v(E3)+3 v(E4)+4 v(E5)+5 v(E6)+6 v(E7)+7 v(E8)+8 v(E9)+9 v(E10)+10 v(E11)+11 v(E12)+12 v(E13)+13 v(E14)+14 v(E15)+15 v(IPG0)/3+(1.65-1.65/3) (v(IPG1)/3+(1.65-1.65/3))+1 (v(IPG2)/3+(1.65-1.65/3))+2 (v(IPG3)/3+(1.65-1.65/3))+3 (v(IPG4)/3+(1.65-1.65/3))+4 (v(IPG5)/3+(1.65-1.65/3))+5 (v(IPG6)/3+(1.65-1.65/3))+6 (v(IPG7)/3+(1.65-1.65/3))+7 (v(IPG8)/3+(1.65-1.65/3))+8 (v(IPG9)/3+(1.65-1.65/3))+9 (v(IPG10)/3+(1.65-1.65/3))+10 (v(IPG11)/3+(1.65-1.65/3))+11 (v(IPG12)/3+(1.65-1.65/3))+12 (v(IPG13)/3+(1.65-1.65/3))+13 (v(IPG14)/3+(1.65-1.65/3))+14 (v(IPG15)/3+(1.65-1.65/3))+15
plot v(REC0) v(REC1)+0.1 v(REC2)+0.2 v(REC3)+0.3 v(REC4)+0.4 v(REC5)+0.5 v(REC6)+0.6 v(REC7)+0.7 v(REC8)+0.8 v(REC9)+0.9 v(REC10)+1 v(REC11)+1.1 v(REC12)+1.2 v(REC13)+1.3 v(REC14)+1.4 v(REC15)+1.5 v(E0) v(E1)+0.1 v(E2)+0.2 v(E3)+0.3 v(E4)+0.4 v(E5)+0.5 v(E6)+0.6 v(E7)+0.7 v(E8)+0.8 v(E9)+0.9 v(E10)+1 v(E11)+1.1 v(E12)+1.2 v(E13)+1.3 v(E14)+1.4 v(E15)+1.5 v(IPG0)/3+(1.65-1.65/3) (v(IPG1)/3+(1.65-1.65/3))+0.1 (v(IPG2)/3+(1.65-1.65/3))+0.2 (v(IPG3)/3+(1.65-1.65/3))+0.3 (v(IPG4)/3+(1.65-1.65/3))+0.4 (v(IPG5)/3+(1.65-1.65/3))+0.5 (v(IPG6)/3+(1.65-1.65/3))+0.6 (v(IPG7)/3+(1.65-1.65/3))+0.7 (v(IPG8)/3+(1.65-1.65/3))+0.8 (v(IPG9)/3+(1.65-1.65/3))+0.9 (v(IPG10)/3+(1.65-1.65/3))+1 (v(IPG11)/3+(1.65-1.65/3))+1.1 (v(IPG12)/3+(1.65-1.65/3))+1.2 (v(IPG13)/3+(1.65-1.65/3))+1.3 (v(IPG14)/3+(1.65-1.65/3))+1.4 (v(IPG15)/3+(1.65-1.65/3))+1.5 xlimit 14m 30m ylimit 1.6 3.2
plot v(REC0) v(REC1)+1 v(REC2)+2 v(REC3)+3 v(REC4)+4 v(REC5)+5 v(REC6)+6 v(REC7)+7 v(REC8)+8 v(REC9)+9 v(REC10)+10 v(REC11)+11 v(REC12)+12 v(REC13)+13 v(REC14)+14 v(REC15)+15 v(E0) v(E1)+1 v(E2)+2 v(E3)+3 v(E4)+4 v(E5)+5 v(E6)+6 v(E7)+7 v(E8)+8 v(E9)+9 v(E10)+10 v(E11)+11 v(E12)+12 v(E13)+13 v(E14)+14 v(E15)+15 v(IPG0)/3+(1.65-1.65/3) (v(IPG1)/3+(1.65-1.65/3))+1 (v(IPG2)/3+(1.65-1.65/3))+2 (v(IPG3)/3+(1.65-1.65/3))+3 (v(IPG4)/3+(1.65-1.65/3))+4 (v(IPG5)/3+(1.65-1.65/3))+5 (v(IPG6)/3+(1.65-1.65/3))+6 (v(IPG7)/3+(1.65-1.65/3))+7 (v(IPG8)/3+(1.65-1.65/3))+8 (v(IPG9)/3+(1.65-1.65/3))+9 (v(IPG10)/3+(1.65-1.65/3))+10 (v(IPG11)/3+(1.65-1.65/3))+11 (v(IPG12)/3+(1.65-1.65/3))+12 (v(IPG13)/3+(1.65-1.65/3))+13 (v(IPG14)/3+(1.65-1.65/3))+14 (v(IPG15)/3+(1.65-1.65/3))+15 xlimit 0m 5m
write tb_realistic_16ch.raw
.endc
"}
